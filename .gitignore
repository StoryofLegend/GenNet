# IDE
.idea/
/shelf/
/workspace.xml
/dataSources/
/dataSources.local.xml
/httpRequests/
*.swp

# Python
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# SLURM logs
logs/

# Raw data symlinks (machine-specific, not portable)
raw_data_input/

# Processed data — large binary files, never commit these
processed_data/*
!processed_data/.gitkeep

# Results — model weights and arrays, too large for git
results/*
!results/.gitkeep

# Large binary formats
*.h5
*.npy
*.npz

# LibreOffice lock files
.~lock.*

# Misc
*.log
examples/A_to_Z/processed_data/*
